#!/usr/bin/env bash
set -euo pipefail

if ! command -v node >/dev/null 2>&1; then
  echo "[gemini-gate] node is required for the Gemini checker gate."
  exit 1
fi

if [ -z "${GEMINI_API_KEY:-}" ]; then
  echo "[gemini-gate] GEMINI_API_KEY is missing. Refusing push."
  echo "[gemini-gate] Set the key in Codespaces secrets or export it in this shell."
  exit 1
fi

node .ai/scripts/gemini-gate.mjs
